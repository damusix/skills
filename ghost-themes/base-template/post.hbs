{{!< default}}

{{#post}}
<article class="single-post {{post_class}}">

    <header class="post-header container">
        {{#if primary_tag}}
            <a class="post-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
        {{/if}}
        <h1 class="post-title">{{title}}</h1>
        <div class="post-meta">
            <span class="post-meta-author">
                {{#primary_author}}
                    <a href="{{url}}">{{name}}</a>
                {{/primary_author}}
            </span>
            <time class="post-meta-date" datetime="{{date format="YYYY-MM-DD"}}">
                {{date format="DD MMM YYYY"}}
            </time>
            <span class="post-meta-reading-time">{{reading_time}}</span>
        </div>
    </header>

    {{#if feature_image}}
    <figure class="post-hero container-wide">
        <img
            class="post-hero-image"
            srcset="
                {{img_url feature_image size="s"}} 400w,
                {{img_url feature_image size="m"}} 750w,
                {{img_url feature_image size="l"}} 960w,
                {{img_url feature_image size="xl"}} 1140w
            "
            sizes="(max-width: 400px) 400px, (max-width: 750px) 750px, (max-width: 960px) 960px, 1140px"
            src="{{img_url feature_image size="xl"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
        >
        {{#if feature_image_caption}}
            <figcaption>{{feature_image_caption}}</figcaption>
        {{/if}}
    </figure>
    {{/if}}

    <div class="post-content container">
        {{content}}
    </div>

    {{> social-links}}

</article>
{{/post}}
