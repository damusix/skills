<header class="site-header">
    <div class="site-header-inner container">
        <div class="site-logo">
            <a href="{{@site.url}}">
                {{#if @site.logo}}
                    <img src="{{img_url @site.logo size="s"}}" alt="{{@site.title}}">
                {{else}}
                    {{@site.title}}
                {{/if}}
            </a>
        </div>

        {{> navigation}}

        <div class="site-header-actions">
            <button class="search-button" data-ghost-search>
                {{t "Search"}}
            </button>

            {{#if @site.members_enabled}}
                {{#unless @member}}
                    {{#unless @site.members_invite_only}}
                        <a href="#/portal/signup" data-portal="signup">{{t "Subscribe"}}</a>
                    {{/unless}}
                    <a href="#/portal/signin" data-portal="signin">{{t "Sign in"}}</a>
                {{else}}
                    <a href="#/portal/account" data-portal="account">{{t "Account"}}</a>
                {{/unless}}
            {{/if}}
        </div>
    </div>
</header>
