    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    <link rel="stylesheet" href="{{asset "built/app.css"}}">
    {{ghost_head}}
</head>
<body class="{{body_class}}{{#if @member}} logged-in{{/if}}">

